# Required
CONFIG_PATH=/data/config.json
S3_BUCKET=your-bucket
S3_ENDPOINT=https://s3.your-provider.example
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
AGE_PASSPHRASE_FILE=/run/secrets/age_passphrase
CRON_SCHEDULE='*/30 * * * *'

# Optional
HEALTHCHECKS_URL=https://hc-ping.com/your-uuid
S3_PREFIX=backrest
AWS_REGION=us-east-1
TZ=Europe/Rome
RUN_TIMEOUT=2m
RUN_ONCE=false

# Optional if your provider uses temporary credentials.
S3_SESSION_TOKEN=
