# Required
CONFIG_PATH=/data/config.json
S3_BUCKET=your-bucket
S3_ENDPOINT=https://s3.your-provider.example
AGE_PASSPHRASE_FILE=/run/secrets/age_passphrase
CRON_SCHEDULE='*/30 * * * *'
HEALTHCHECKS_URL=https://hc-ping.com/your-uuid

# Optional
S3_PREFIX=backrest
AWS_REGION=us-east-1
TZ=Europe/Rome
RUN_TIMEOUT=2m
RUN_ONCE=false

# Provide credentials only if your environment does not already supply them.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
